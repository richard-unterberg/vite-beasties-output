{
  "name": "@unterberg/vite-beasties-output",
  "version": "0.1.12",
  "description": "Post-build vite plugin that runs beasties against already generated HTML output.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node18",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "verify": "pnpm knip && pnpm format && pnpm run lint && pnpm run typecheck && pnpm run test",
    "prepublishOnly": "pnpm run verify && pnpm pack --dry-run",
    "deploy:npm": "node ./scripts/deploy.mjs"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "vike",
    "beasties",
    "critical-css",
    "ssg"
  ],
  "license": "ISC",
  "dependencies": {
    "beasties": "latest"
  },
  "peerDependencies": {
    "vite": ">=6"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.0",
    "knip": "^6.18.0",
    "lefthook": "^2.1.9",
    "tsup": "^8.5.1",
    "vite": "^8.1.0",
    "typescript": "^6.0.3"
  }
}
